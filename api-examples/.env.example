# Copy to .env and fill in. Loaded automatically by the tools.

# --- Single workspace ---------------------------------------------------------
# Used when you don't pass --profile. The tenant path is always /tenants/spar/api;
# only the deployment subdomain changes.
SEMA4_BASE_URL=https://your-deployment.app.sema4.ai/tenants/spar/api/v2
SEMA4_API_KEY=s4w_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Profiles (operating several workspaces) ----------------------------------
# When you use sema4-profiles.yaml, its api_key: ${VAR} refs resolve from here.
# Name one var per workspace, matching your profiles file:
# GOLDEN_API_KEY=s4w_...
# EU_API_KEY=s4w_...

# Per-workspace clone secrets (DB passwords, etc.) live in *.secrets.env files
# written by 03-clone-workspace/export.py — not here.
