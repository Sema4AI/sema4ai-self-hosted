# Copy to .env and fill in. Both values are required by every workflow.

# Base URL of your deployment's v2 API.
SEMA4_BASE_URL=https://your-deployment.app.sema4.ai/tenants/spar/api/v2

# API key from Configuration -> API keys. Sent as: Authorization: Bearer <key>
SEMA4_API_KEY=s4w_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
