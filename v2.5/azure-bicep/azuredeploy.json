                "description": "Data disk size in GB (mounted at /var/lib/embedded-cluster)."
              }
            }
          },
          "variables": {
            "$fxv#0": "#cloud-config\npackage_update: true\npackage_upgrade: false\n\npackages:\n  - curl\n  - ca-certificates\n  - jq\n  - postgresql-client\n\nwrite_files:\n  - path: /etc/profile.d/s4-banner.sh\n    permissions: '0644'\n    content: |\n      cat <<'BANNER'\n\n      ── Sema4.ai self-hosted ──────────────────────────────────────────────\n      This VM is provisioned for hosting Sema4.ai via Replicated Embedded Cluster.\n\n      Install instructions: https://get.sema4.ai\n\n      KOTS admin console (after install) — tunnel from your laptop with:\n        ssh -L 8800:localhost:30000 <user>@<this-vm>\n        then open https://localhost:8800\n\n      Cluster shell (after install) — exports KUBECONFIG and PATH for\n      kubectl, k0s, helm, etc:\n        /var/lib/embedded-cluster/bin/sema4ai shell\n\n      Install k9s for an interactive cluster TUI:\n        curl -sS https://webi.sh/k9s | sh\n        source ~/.config/envman/PATH.env\n      ──────────────────────────────────────────────────────────────────────\n\n      BANNER\n\nmounts:\n  - ['/dev/disk/azure/scsi1/lun0-part1', '/var/lib/embedded-cluster', 'ext4', 'defaults,nofail', '0', '2']\n\ndisk_setup:\n  /dev/disk/azure/scsi1/lun0:\n    table_type: gpt\n    layout: true\n    overwrite: false\n\nfs_setup:\n  - device: /dev/disk/azure/scsi1/lun0\n    partition: 1\n    filesystem: ext4\n    overwrite: false\n",
            "vmName": "[format('vm-{0}', parameters('infraId'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Network/publicIPAddresses",
              "apiVersion": "2023-11-01",
              "name": "[format('{0}-pip', variables('vmName'))]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Standard"
              },
              "properties": {
                "publicIPAllocationMethod": "Static",
                "dnsSettings": {
                  "domainNameLabel": "[parameters('infraId')]"
                }
              }
            },
            {
              "type": "Microsoft.Network/networkSecurityGroups",
              "apiVersion": "2023-11-01",
              "name": "[format('{0}-nsg', variables('vmName'))]",
              "location": "[parameters('location')]",
              "properties": {
                "securityRules": [
                  {
                    "name": "AllowHttpsFromInternet",
                    "properties": {
                      "priority": 110,
                      "direction": "Inbound",
                      "access": "Allow",
                      "protocol": "Tcp",
                      "sourcePortRange": "*",
                      "destinationPortRange": "443",
                      "sourceAddressPrefix": "Internet",
                      "destinationAddressPrefix": "*"
                    }
                  },
                  {
                    "name": "AllowAdminSSH",
                    "properties": {
                      "priority": 200,
                      "direction": "Inbound",
                      "access": "Allow",
                      "protocol": "Tcp",
                      "sourcePortRange": "*",
                      "destinationPortRange": "22",
                      "sourceAddressPrefix": "[parameters('adminSshCidr')]",
                      "destinationAddressPrefix": "*"
                    }
                  },
                  {
                    "name": "DenyAllOtherInbound",
                    "properties": {
                      "priority": 4000,
                      "direction": "Inbound",
                      "access": "Deny",
                      "protocol": "*",
                      "sourcePortRange": "*",
                      "destinationPortRange": "*",
                      "sourceAddressPrefix": "*",
                      "destinationAddressPrefix": "*"
                    }
                  }
                ]
              }
            },
            {
              "type": "Microsoft.Network/networkInterfaces",
              "apiVersion": "2023-11-01",
              "name": "[format('{0}-nic', variables('vmName'))]",
              "location": "[parameters('location')]",
              "properties": {
                "networkSecurityGroup": {
                  "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('{0}-nsg', variables('vmName')))]"
                },
                "ipConfigurations": [
                  {
                    "name": "primary",
                    "properties": {
                      "subnet": {
                        "id": "[parameters('vmSubnetId')]"
                      },
                      "privateIPAllocationMethod": "Dynamic",
                      "publicIPAddress": {
                        "id": "[resourceId('Microsoft.Network/publicIPAddresses', format('{0}-pip', variables('vmName')))]"
                      }
                    }
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/networkSecurityGroups', format('{0}-nsg', variables('vmName')))]",
                "[resourceId('Microsoft.Network/publicIPAddresses', format('{0}-pip', variables('vmName')))]"
              ]
            },
            {
              "type": "Microsoft.Compute/virtualMachines",
              "apiVersion": "2024-07-01",
              "name": "[variables('vmName')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('identityId'))]": {}
                }
              },
              "properties": {
                "hardwareProfile": {
                  "vmSize": "[parameters('vmSize')]"
                },
                "osProfile": {
                  "computerName": "[variables('vmName')]",
                  "adminUsername": "[parameters('adminUsername')]",
                  "customData": "[base64(variables('$fxv#0'))]",
                  "linuxConfiguration": {
                    "disablePasswordAuthentication": true,
                    "ssh": {
                      "publicKeys": [
                        {
                          "path": "[format('/home/{0}/.ssh/authorized_keys', parameters('adminUsername'))]",
                          "keyData": "[parameters('adminSshPublicKey')]"
                        }
                      ]
                    }
                  }
                },
                "storageProfile": {
                  "imageReference": {
                    "publisher": "Canonical",
                    "offer": "ubuntu-24_04-lts",
                    "sku": "server",
                    "version": "latest"
                  },
                  "osDisk": {
                    "name": "[format('{0}-osdisk', variables('vmName'))]",
                    "caching": "ReadWrite",
                    "createOption": "FromImage",
                    "managedDisk": {
                      "storageAccountType": "Premium_LRS"
                    },
                    "diskSizeGB": 64
                  },
                  "dataDisks": [
                    {
                      "name": "[format('{0}-datadisk', variables('vmName'))]",
                      "lun": 0,
                      "caching": "ReadWrite",
                      "createOption": "Empty",
                      "diskSizeGB": "[parameters('dataDiskSizeGB')]",
                      "managedDisk": {
                        "storageAccountType": "Premium_LRS"
                      }
                    }
                  ]
                },
                "networkProfile": {
                  "networkInterfaces": [
                    {
                      "id": "[resourceId('Microsoft.Network/networkInterfaces', format('{0}-nic', variables('vmName')))]"
                    }
                  ]
                },
                "diagnosticsProfile": {
                  "bootDiagnostics": {
                    "enabled": true
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/networkInterfaces', format('{0}-nic', variables('vmName')))]"
              ]
            }
          ],
          "outputs": {
            "vmPublicIp": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', format('{0}-pip', variables('vmName'))), '2023-11-01').ipAddress]"
            },
            "vmPublicFqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', format('{0}-pip', variables('vmName'))), '2023-11-01').dnsSettings.fqdn]"
            },
            "vmPrivateIp": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/networkInterfaces', format('{0}-nic', variables('vmName'))), '2023-11-01').ipConfigurations[0].properties.privateIPAddress]"
            },
            "adminUsername": {
              "type": "string",
              "value": "[parameters('adminUsername')]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'networking')]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'vm-identity')]"
      ]
    }
  ],
  "outputs": {
    "vmPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'vm'), '2025-04-01').outputs.vmPublicIp.value]"
    },
    "vmPublicFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'vm'), '2025-04-01').outputs.vmPublicFqdn.value]"
    },
    "sshCommand": {
      "type": "string",
      "value": "[format('ssh {0}@{1}', parameters('adminUsername'), if(empty(parameters('customHostname')), reference(resourceId('Microsoft.Resources/deployments', 'vm'), '2025-04-01').outputs.vmPublicFqdn.value, parameters('customHostname')))]"
    },
    "kotsAdminConsoleSshCommand": {
      "type": "string",
      "value": "[format('ssh -L 8800:localhost:30000 {0}@{1}', parameters('adminUsername'), if(empty(parameters('customHostname')), reference(resourceId('Microsoft.Resources/deployments', 'vm'), '2025-04-01').outputs.vmPublicFqdn.value, parameters('customHostname')))]"
    },
    "externalUrl": {
      "type": "string",
      "value": "[format('https://{0}', if(empty(parameters('customHostname')), reference(resourceId('Microsoft.Resources/deployments', 'vm'), '2025-04-01').outputs.vmPublicFqdn.value, parameters('customHostname')))]"
    },
    "infrastructurePlatform": {
      "type": "string",
      "value": "Microsoft Azure"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage'), '2025-04-01').outputs.storageAccountName.value]"
    },
    "blobContainerName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage'), '2025-04-01').outputs.storageContainerName.value]"
    },
    "blobKeyPrefix": {
      "type": "string",
      "value": "[parameters('infraId')]"
    },
    "keyVaultKeyUrl": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'keyvault'), '2025-04-01').outputs.keyVaultKeyUrl.value]"
    },
    "postgresHost": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'postgres'), '2025-04-01').outputs.host.value]"
    },
    "postgresPort": {
      "type": "string",
      "value": "5432"
    },
    "postgresUser": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'postgres'), '2025-04-01').outputs.user.value]"
    },
    "postgresDatabase": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'postgres'), '2025-04-01').outputs.database.value]"
    },
    "postgresPassword": {
      "type": "string",
      "value": "[parameters('postgresAdminPassword')]"
    },
    "oidcClientId": {
      "type": "string",
      "metadata": {
        "description": "OIDC is not provisioned by this template. Register an app with your IdP and fill these in the KOTS console."
      },
      "value": "REPLACE_ME"
    },
    "oidcClientSecret": {
      "type": "string",
      "value": "REPLACE_ME"
    },
    "oidcServer": {
      "type": "string",
      "value": "REPLACE_ME"
    }
  }
}